# Copy to .env.local and adjust. Restart `npm run dev` after changes (Vite bakes VITE_* at startup).

# Live mortgage dashboard (local): run the fanniemae dashboard on 5173, then point the portfolio here.
# Use another port for this site (e.g. npm run dev -- --port 5174) so both apps can run at once.
VITE_MORTGAGE_DASHBOARD_URL=http://127.0.0.1:5173
