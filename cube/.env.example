# Cube config — copy to .env and fill from your Neon portfolio DB (DATABASE_URL).
# scripts/gen-cube-env.mjs generates .env automatically from ../.env.local.
CUBEJS_DEV_MODE=true
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=your-neon-host.neon.tech
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=neondb
CUBEJS_DB_USER=neondb_owner
CUBEJS_DB_PASS=your-password
CUBEJS_DB_SSL=true
CUBEJS_API_SECRET=change-me-to-a-long-random-string
